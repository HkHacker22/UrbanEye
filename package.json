{
  "name": "smart-civic-platform",
  "version": "1.0.0",
  "description": "Smart Civic Issue & Safety Platform",
  "scripts": {
  "frontend": "npm run dev --prefix frontend",
  "backend": "node api/index.js",
  "build": "cd frontend && npm install && npm run build && cd .. && rm -rf dist && cp -r frontend/dist dist",
  "dev": "concurrently \"npm run backend\" \"npm run frontend\""
},
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
